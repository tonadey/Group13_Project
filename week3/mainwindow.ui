              </widget>
             </item>
            </layout>
           </item>
          </layout>
         </widget>
        </item>
        <item>
         <widget class="QGroupBox" name="loadGroupBox">
          <property name="title">
           <string>Load Models</string>
          </property>
          <layout class="QVBoxLayout" name="verticalLayout_load">
           <item>
            <widget class="QPushButton" name="openFileButton">
             <property name="text">
              <string>Open STL File...</string>
             </property>
             <property name="icon">
              <iconset resource="icons.qrc">
               <normaloff>:/Icons/icons/fileopen.png</normaloff>:/Icons/icons/fileopen.png</iconset>
             </property>
            </widget>
           </item>
           <item>
            <widget class="QPushButton" name="openFolderButton">
             <property name="text">
              <string>Open Folder of STLs...</string>
             </property>
             <property name="icon">
              <iconset resource="icons.qrc">
               <normaloff>:/Icons/icons/fileopen.png</normaloff>:/Icons/icons/fileopen.png</iconset>
             </property>
            </widget>
           </item>
          </layout>
         </widget>
        </item>
       </layout>
      </widget>
      <widget class="QWidget" name="rightPanel" native="true">
       <layout class="QVBoxLayout" name="verticalLayout_right">
        <item>
         <widget class="QVTKOpenGLNativeWidget" name="vtkWidget" native="true">
          <property name="minimumSize">
           <size>
            <width>500</width>
            <height>450</height>
           </size>
          </property>
         </widget>
        </item>
        <item>
         <widget class="QGroupBox" name="viewGroupBox">
          <property name="title">
           <string>View Controls</string>
          </property>
          <layout class="QGridLayout" name="gridLayout_view">
           <item row="2" column="2">
            <widget class="QCheckBox" name="visibilityCheckBox">
             <property name="text">
              <string>Visible</string>
             </property>
             <property name="checked">
              <bool>true</bool>
             </property>
            </widget>
           </item>
           <item row="0" column="2">
            <widget class="QPushButton" name="backgroundColourButton">
             <property name="text">
              <string>Background Colour</string>
             </property>
            </widget>
           </item>
           <item row="1" column="0">
            <widget class="QLabel" name="lightIntensityLabel">
             <property name="text">
              <string>Light Intensity</string>
             </property>
            </widget>
           </item>
           <item row="1" column="1" colspan="2">
            <widget class="QSlider" name="lightSlider">
             <property name="minimum">
              <number>0</number>
             </property>
             <property name="maximum">
              <number>100</number>
             </property>
             <property name="value">
              <number>50</number>
             </property>
             <property name="orientation">
              <enum>Qt::Orientation::Horizontal</enum>
             </property>
            </widget>
           </item>
           <item row="0" column="0">
            <widget class="QPushButton" name="resetViewButton">
             <property name="text">
              <string>Reset Model View</string>
             </property>
            </widget>
           </item>
           <item row="2" column="1">
            <widget class="QSlider" name="shrinkSlider">
             <property name="maximum">
              <number>100</number>
             </property>
             <property name="orientation">
              <enum>Qt::Orientation::Horizontal</enum>
             </property>
            </widget>
           </item>
           <item row="0" column="1">
            <widget class="QPushButton" name="changeColourButton">
             <property name="text">
              <string>Change Model Colour</string>
             </property>
            </widget>
