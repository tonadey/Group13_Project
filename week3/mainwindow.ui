              <string>Light Intensity</string>
             </property>
            </widget>
           </item>
           <item row="1" column="1" colspan="2">
            <widget class="QSlider" name="lightSlider">
             <property name="minimum">
              <number>0</number>
             </property>
             <property name="maximum">
              <number>100</number>
             </property>
             <property name="value">
              <number>50</number>
             </property>
             <property name="orientation">
              <enum>Qt::Orientation::Horizontal</enum>
             </property>
            </widget>
           </item>
           <item row="2" column="0">
            <widget class="QLabel" name="shrinkLabel">
             <property name="toolTip">
              <string>Shrink filter (vtkShrinkFilter): 0 = no shrink, 100 = max shrink. Per-part.</string>
             </property>
             <property name="text">
              <string>Shrink intensity:</string>
             </property>
            </widget>
           </item>
           <item row="2" column="1">
            <widget class="QSlider" name="shrinkSlider">
             <property name="toolTip">
              <string>Drag to shrink the selected part. Updates VR via Sync.</string>
             </property>
             <property name="maximum">
              <number>100</number>
             </property>
             <property name="orientation">
              <enum>Qt::Orientation::Horizontal</enum>
             </property>
            </widget>
           </item>
           <item row="3" column="0">
            <widget class="QLabel" name="clipLabel">
             <property name="toolTip">
              <string>Clip plane along X axis (vtkClipDataSet). 0 = off, 100 = clip past max X. Per-part.</string>
             </property>
             <property name="text">
              <string>Clip position:</string>
             </property>
            </widget>
           </item>
           <item row="3" column="1">
            <widget class="QSlider" name="clipSlider">
             <property name="toolTip">
              <string>Drag to slice the selected part. Updates VR via Sync.</string>
             </property>
             <property name="maximum">
              <number>100</number>
             </property>
             <property name="orientation">
              <enum>Qt::Orientation::Horizontal</enum>
             </property>
            </widget>
           </item>
           <item row="2" column="2">
            <widget class="QCheckBox" name="visibilityCheckBox">
             <property name="toolTip">
              <string>Show or hide the selected part in both views</string>
             </property>
             <property name="text">
              <string>Visible</string>
             </property>
             <property name="checked">
              <bool>true</bool>
             </property>
            </widget>
           </item>
           <item row="4" column="0">
            <widget class="QLabel" name="explodeLabel">
             <property name="toolTip">
              <string>One-click animated exploded view. Pick a direction, then click the button to fly the parts apart (or back together) over ~1 second.</string>
             </property>
             <property name="text">
              <string>Explode:</string>
             </property>
            </widget>
           </item>
           <item row="4" column="1">
            <widget class="QComboBox" name="explodeModeBox">
             <property name="toolTip">
              <string>Direction for the exploded view. Spherical = each part flies radially from the model centre. X / Y / Z = parts spread along just that axis.</string>
             </property>
             <item>
              <property name="text">
               <string>Spherical</string>
              </property>
             </item>
             <item>
              <property name="text">
               <string>X-axis</string>
              </property>
             </item>
             <item>
              <property name="text">
               <string>Y-axis</string>
              </property>
             </item>
             <item>
              <property name="text">
               <string>Z-axis</string>
              </property>
             </item>
            </widget>
           </item>
           <item row="4" column="2">
            <widget class="QPushButton" name="explodeButton">
             <property name="toolTip">
              <string>Animate parts apart (or back together). VR auto-syncs at the end of the animation.</string>
             </property>
             <property name="text">
              <string>Explode</string>
             </property>
             <property name="checkable">
              <bool>true</bool>
             </property>
            </widget>
           </item>
           <item row="5" column="0">
            <widget class="QLabel" name="opacityLabel">
             <property name="toolTip">
              <string>Drag to make every visible part semi-transparent. 100 = solid, 0 = invisible. Lets you see through the outer shell to spot internal geometry.</string>
             </property>
             <property name="text">
              <string>X-ray Opacity:</string>
             </property>
            </widget>
           </item>
           <item row="5" column="1">
            <widget class="QSlider" name="opacitySlider">
             <property name="toolTip">
              <string>Global opacity for every visible part. VR auto-syncs on slider release.</string>
             </property>
             <property name="maximum">
              <number>100</number>
             </property>
             <property name="value">
              <number>100</number>
             </property>
             <property name="orientation">
