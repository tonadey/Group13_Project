 <class>MainWindow</class>
 <widget class="QMainWindow" name="MainWindow">
  <property name="geometry">
   <rect>
    <x>0</x>
    <y>0</y>
    <width>1213</width>
    <height>780</height>
   </rect>
  </property>
  <property name="windowTitle">
   <string>Group 13 - CAD Viewer</string>
  </property>
  <property name="styleSheet">
   <string notr="true">QMainWindow {
    background: #f4f5f7;
}
QGroupBox {
    font-weight: 600;
    color: #2a3142;
    border: 1px solid #c5cad3;
    border-radius: 6px;
    margin-top: 9px;
    padding: 8px 6px 5px 6px;
    background: #fafbfc;
}
QGroupBox::title {
    subcontrol-origin: margin;
    subcontrol-position: top left;
    left: 8px;
    padding: 0 5px;
    color: #1f5fb4;
}
QPushButton {
    padding: 4px 12px;
    min-height: 22px;
    border: 1px solid #b8bdc7;
    border-radius: 4px;
    background: qlineargradient(x1:0, y1:0, x2:0, y2:1,
                                stop:0 #ffffff, stop:1 #e8ecf2);
    color: #1f2530;
}
QPushButton:hover {
    border-color: #4a90d9;
    background: qlineargradient(x1:0, y1:0, x2:0, y2:1,
                                stop:0 #ffffff, stop:1 #d6e4f5);
}
QPushButton:pressed {
    background: #c2d4ec;
}
QPushButton:disabled {
    color: #a0a4ad;
    background: #ededed;
}
QCheckBox { spacing: 5px; }
QLabel { padding: 0; color: #2a3142; }
QTreeView {
    border: 1px solid #c5cad3;
    border-radius: 4px;
    background: #ffffff;
    alternate-background-color: #f5f7fa;
    selection-background-color: #4a90d9;
    selection-color: #ffffff;
}
QTreeView::item { padding: 2px 0; }
QDoubleSpinBox, QSpinBox {
    padding: 1px 2px;
    min-height: 18px;
    border: 1px solid #b8bdc7;
    border-radius: 3px;
}
QSlider::groove:horizontal {
    height: 5px;
    background: #d0d4dc;
    border-radius: 2px;
}
QSlider::sub-page:horizontal {
    background: #4a90d9;
    border-radius: 2px;
}
QSlider::handle:horizontal {
    width: 13px;
    margin: -5px 0;
    background: qradialgradient(cx:0.5, cy:0.5, radius:0.5,
                                fx:0.5, fy:0.4,
                                stop:0 #6aa9e0, stop:1 #2a70b9);
    border-radius: 6px;
    border: 1px solid #1f5fb4;
}
QSlider::handle:horizontal:hover {
    background: qradialgradient(cx:0.5, cy:0.5, radius:0.5,
                                fx:0.5, fy:0.4,
                                stop:0 #87bce7, stop:1 #3a80c9);
}
QStatusBar {
    background: #2a3142;
    color: #e8ecf2;
}
QToolBar {
    border-bottom: 1px solid #c5cad3;
    background: #fafbfc;
    spacing: 2px;
    padding: 2px;
}
QMenuBar {
    background: #fafbfc;
    border-bottom: 1px solid #c5cad3;
}
QMenuBar::item:selected { background: #d6e4f5; }
QMenu { background: #ffffff; border: 1px solid #c5cad3; }
QMenu::item:selected { background: #4a90d9; color: #ffffff; }</string>
  </property>
