   </rect>
  </property>
  <property name="windowTitle">
   <string>Group 13 - CAD Viewer</string>
  </property>
  <widget class="QWidget" name="centralwidget">
   <layout class="QHBoxLayout" name="horizontalLayout_main">
    <item>
     <widget class="QSplitter" name="mainSplitter">
      <property name="orientation">
       <enum>Qt::Orientation::Horizontal</enum>
      </property>
      <widget class="QWidget" name="leftPanel" native="true">
       <layout class="QVBoxLayout" name="verticalLayout_left">
        <item>
         <widget class="QGroupBox" name="treeGroupBox">
          <property name="title">
           <string>Model Parts</string>
          </property>
          <layout class="QVBoxLayout" name="verticalLayout_tree">
           <item>
            <widget class="QTreeView" name="treeView">
             <property name="contextMenuPolicy">
              <enum>Qt::ContextMenuPolicy::ActionsContextMenu</enum>
             </property>
            </widget>
           </item>
           <item>
