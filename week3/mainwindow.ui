            </widget>
           </item>
           <item row="5" column="2">
            <widget class="QPushButton" name="opacitySolidButton">
             <property name="toolTip">
              <string>Snap opacity back to 100% (turn X-ray off in one click).</string>
             </property>
             <property name="text">
              <string>Solid</string>
             </property>
            </widget>
           </item>
          </layout>
